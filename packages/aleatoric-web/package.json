{
  "name": "aleatoric-web",
  "version": "0.1.0",
  "description": "Web Audio engine, playback scheduler, and interactive docs for aleatoric",
  "author": "Collin Klippel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/collin-klippel/aleatoric.git",
    "directory": "packages/aleatoric-web"
  },
  "homepage": "https://github.com/collin-klippel/aleatoric#readme",
  "bugs": {
    "url": "https://github.com/collin-klippel/aleatoric/issues"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p docs/tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:dev": "vite",
    "docs:build": "vite build",
    "docs:preview": "vite preview"
  },
  "keywords": [
    "music",
    "aleatoric",
    "web-audio",
    "generative",
    "synthesizer",
    "sequencer",
    "scheduler"
  ],
  "peerDependencies": {
    "aleatoric": "^0.1.0"
  },
  "devDependencies": {
    "aleatoric": "^0.1.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@uiw/react-codemirror": "^4.25.9",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.27.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^6.0.0"
  }
}
